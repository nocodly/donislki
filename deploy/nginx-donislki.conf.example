# Додати в конфіг сервера nocodly.com, всередину існуючого server { ... } блоку.
# Передбачає, що застосунок DonislKI запущено локально на порту 3000
# з BASE_PATH=/donislki у .env.

location /donislki/ {
    proxy_pass http://127.0.0.1:3000/donislki/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
}
